NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Plant Access Control"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=geno_challenge

# Database option A: Google Cloud SQL from Cloud Run.
# Recommended production setup:
# - Attach the Cloud SQL instance to the Cloud Run service.
# - Grant the Cloud Run service account roles/cloudsql.client.
# - Store real credentials only in deployment environment variables or secrets.
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@localhost/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE&schema=public"

# DIRECT_URL is not required by the running Cloud Run app. It is required for
# Prisma CLI commands because prisma/schema.prisma defines directUrl.
DIRECT_URL="postgresql://DB_USER:DB_PASSWORD@localhost/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE&schema=public"

# Database option B: Docker local PostgreSQL from the app container.
# Use these values when running the Docker app against the db service.
# DATABASE_URL="postgresql://postgres:postgres@db:5432/geno_challenge?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@db:5432/geno_challenge?schema=public"

# Database option C: Docker local PostgreSQL from host-run Prisma commands.
# Use localhost when running npm/npx Prisma commands on the host machine.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geno_challenge?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/geno_challenge?schema=public"

GUARD_PIN="1234"
SESSION_SECRET="replace-with-a-long-random-secret"
SESSION_COOKIE_SECURE="false"
