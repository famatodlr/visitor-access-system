NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Plant Access Control"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=geno_challenge

# Database option A: Neon / remote PostgreSQL.
# Use the pooled connection string for DATABASE_URL and the direct connection
# string for DIRECT_URL. Keep real values only in your local .env or deployment
# environment variables.
DATABASE_URL="postgresql://USER:PASSWORD@REMOTE_HOST/DB_NAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@REMOTE_HOST/DB_NAME?sslmode=require"

# Database option B: Docker local PostgreSQL from the app container.
# Use these values when running the Docker app against the db service.
# DATABASE_URL="postgresql://postgres:postgres@db:5432/geno_challenge?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@db:5432/geno_challenge?schema=public"

# Database option C: Docker local PostgreSQL from host-run Prisma commands.
# Use localhost when running npm/npx Prisma commands on the host machine.
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geno_challenge?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/geno_challenge?schema=public"

GUARD_PIN="1234"
SESSION_SECRET="replace-with-a-long-random-secret"
SESSION_COOKIE_SECURE="false"
